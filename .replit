modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "QB Portal"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "product-integrity"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "route-check"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "price-consistency"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-health"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "task-compliance"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=19446 BASE_PATH=/ pnpm --filter @workspace/nexfortis run dev"
waitForPort = 19446

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "QB Portal"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=20914 BASE_PATH=/qb-portal/ pnpm --filter @workspace/qb-portal run dev"
waitForPort = 20914

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/validations/typecheck.sh"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "product-integrity"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/validations/product-integrity.mjs"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "route-check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/validations/route-check.mjs"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "price-consistency"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/validations/price-consistency.mjs"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-health"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/validations/api-health.sh"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "task-compliance"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/validations/task-compliance.mjs"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
