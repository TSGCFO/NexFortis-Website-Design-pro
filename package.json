{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "start": "node artifacts/api-server/dist/index.cjs",
    "test": "node --test 'tests/*.test.mjs'",
    "test:seo": "pnpm test:seo:lib && pnpm test:seo:verifiers && pnpm test:seo:components && pnpm test:seo:snapshots && pnpm test:seo:invariants",
    "test:seo:fast": "pnpm test:seo:lib && pnpm test:seo:verifiers && pnpm test:seo:components",
    "test:seo:lib": "node --test 'tests/seo/lib/*.test.mjs'",
    "test:seo:verifiers": "node --test 'scripts/seo-verification/*.test.mjs'",
    "test:seo:snapshots": "node --test 'tests/seo/snapshots.test.mjs'",
    "test:seo:invariants": "node --test 'tests/seo/invariants.test.mjs'",
    "test:seo:audit:qb-privacy-bold": "node --test 'tests/seo/qb-privacy-bold.test.mjs'",
    "test:seo:components": "vitest run --config vitest.config.ts",
    "test:seo:update": "UPDATE_SNAPSHOTS=1 node --test 'tests/seo/snapshots.test.mjs'"
  },
  "private": true,
  "devDependencies": {
    "@tanstack/react-query": "catalog:",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "catalog:",
    "cheerio": "^1.2.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-helmet-async": "^3.0.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5",
    "wouter": "^3.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "puppeteer"
    ],
    "overrides": {
      "zod": "3.25.76"
    }
  }
}
